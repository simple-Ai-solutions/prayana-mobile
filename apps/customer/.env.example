# Customer mobile app environment template.
# Copy to `.env`, fill values, then `npx expo start --clear`.

# Build environment ('development' | 'staging' | 'production').
# Set automatically by eas.json profiles. Override locally if needed.
EXPO_PUBLIC_ENV=development

# ===== API =====
# Local dev (laptop hosting the Express server):
# EXPO_PUBLIC_API_URL=http://localhost:5000/api
# EXPO_PUBLIC_SOCKET_URL=http://localhost:5000

# Production:
EXPO_PUBLIC_API_URL=https://api.prayanaai.com/api
EXPO_PUBLIC_SOCKET_URL=https://api.prayanaai.com

# ===== Firebase (project: prayanaai-d52cc) =====
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=prayanaai-d52cc.firebaseapp.com
EXPO_PUBLIC_FIREBASE_PROJECT_ID=prayanaai-d52cc
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=prayanaai-d52cc.firebasestorage.app
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=926782873134
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ===== Google Sign-In =====
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# ===== Maps =====
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=

# ===== Image CDN =====
EXPO_PUBLIC_S3_BASE_URL=https://travel-app-image-travel-ai.s3.ap-south-1.amazonaws.com
EXPO_PUBLIC_CDN_URL=https://prayanaai.com

# ===== Razorpay =====
# Test key for dev/preview, live key for production. Server holds the secret.
EXPO_PUBLIC_RAZORPAY_KEY_ID=

# ===== Support =====
EXPO_PUBLIC_ENQUIRY_WHATSAPP=919449753920
EXPO_PUBLIC_ENQUIRY_EMAIL=simpleaisolutions@prayanaai.com

# ===== Sentry =====
# Empty in dev → Sentry init is a no-op. Required for production builds.
EXPO_PUBLIC_SENTRY_DSN=
# Sample rate for performance traces (0..1). Default: 0.1 in prod, 0 elsewhere.
EXPO_PUBLIC_SENTRY_TRACES_RATE=

# ===== Analytics =====
EXPO_PUBLIC_GA_MEASUREMENT_ID=
